{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: uvicorn main:app",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "PYTHONDONTWRITEBYTECODE": "1"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
