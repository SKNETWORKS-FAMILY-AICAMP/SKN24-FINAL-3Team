# Application
APP_NAME=ALPLED-CORE
APP_ENV=local
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/alpled

# S3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-northeast-2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=arkive

# LLM
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192

# Storage
LOCAL_STORAGE_ROOT=./storage
INPUT_DIR=./storage/input
OUTPUT_DIR=./storage/output
TEMP_DIR=./storage/temp
EXTRACT_IMAGE_DIR=./storage/extracted_images
MERMAID_DIR=./storage/mermaid

# Log
LOG_LEVEL=INFO
LOG_FILE=./logs/alpled.log

# Supervisor
MAX_ROUND=3
