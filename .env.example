# ==================================================
# APP
# ==================================================

APP_NAME=ALPLED-CORE
APP_ENV=local
APP_DEBUG=true

# ==================================================
# FASTAPI
# ==================================================

HOST=0.0.0.0
PORT=8000

# ==================================================
# DATABASE
# ==================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=alpled
DB_USER=root
DB_PASSWORD=1234

DATABASE_URL=mysql+pymysql://root:1234@localhost:3306/alpled

# ==================================================
# S3
# ==================================================

S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-northeast-2

# ==================================================
# QDRANT
# ==================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333

QDRANT_COLLECTION=arkive

# ==================================================
# EMBEDDING
# ==================================================

EMBEDDING_MODEL=BAAI/bge-m3

# ==================================================
# LLM
# ==================================================

LLM_BASE_URL=http://localhost:8000/v1

LLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct

LLM_TIMEOUT=300

LLM_TEMPERATURE=0.2

LLM_MAX_TOKENS=8192

# ==================================================
# WEB SEARCH
# ==================================================

SERPER_API_KEY=

# ==================================================
# STORAGE
# ==================================================

LOCAL_STORAGE_ROOT=./storage

INPUT_DIR=./storage/input
OUTPUT_DIR=./storage/output

TEMP_DIR=./storage/temp

EXTRACT_IMAGE_DIR=./storage/extracted_images

MERMAID_DIR=./storage/mermaid

# ==================================================
# MERMAID
# ==================================================

MERMAID_CLI_PATH=mmdc

# ==================================================
# SUPERVISOR
# ==================================================

MAX_ROUND=3

VALIDATION_RETRY_LIMIT=2

# ==================================================
# LOG
# ==================================================

LOG_LEVEL=INFO

LOG_FILE=./logs/alpled.log
# ==================================================
# DOC TEMPLATE
# ==================================================

SRS_TEMPLATE=templates/srs_template.docx

INTERFACE_TEMPLATE=templates/interface_template.docx

ERD_TEMPLATE=templates/erd_template.docx

DB_TEMPLATE=templates/db_template.docx

ARCH_TEMPLATE=templates/arch_template.docx

TS_TEMPLATE=templates/ts_template.docx

# ==================================================
# DOC STATUS CODE
# ==================================================

DOC_STATUS_READY=01
DOC_STATUS_GENERATING=02
DOC_STATUS_SUCCESS=03
DOC_STATUS_FAIL=04

# ==================================================
# DOCS_CD
# ==================================================

DOCS_CD_SRS=SRS
DOCS_CD_INTERFACE=INTERFACE
DOCS_CD_ERD=ERD
DOCS_CD_DB=DB
DOCS_CD_ARCH=ARCH
DOCS_CD_TS=TS