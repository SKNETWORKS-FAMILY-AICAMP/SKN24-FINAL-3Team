# Application
APP_NAME=ALPLED-CORE
APP_ENV=local
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DB_DRIVER=mysql+pymysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alpled_db
DB_USER=alpled
DB_PASSWORD=

# S3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-northeast-2

# Qdrant
# QDRANT_URL을 지정하면 아래 HOST/PORT보다 우선합니다.
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
ALPLED_REFERENCE_COLLECTION=ALPLED_reference

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3

# LLM
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL_NAME=Qwen/Qwen3-VL-8B-Instruct
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192

# Storage
LOCAL_STORAGE_ROOT=./storage
INPUT_DIR=./storage/input
OUTPUT_DIR=./storage/output
TEMP_DIR=./storage/temp
EXTRACT_IMAGE_DIR=./storage/extracted_images
MERMAID_DIR=./storage/mermaid
MERMAID_CLI_PATH=mmdc
MERMAID_RENDER_WIDTH=1600
MERMAID_RENDER_HEIGHT=1200
MERMAID_RENDER_SCALE=2

# Log
LOG_LEVEL=INFO
LOG_FILE=./logs/alpled.log

# Supervisor
MAX_ROUND=3
